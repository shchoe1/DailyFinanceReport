# 카카오 개발자(https://developers.kakao.com) 에서 발급받은 값으로 채우고
# 이 파일을 '.env' 로 복사하세요.  (copy .env.example .env)

# 내 애플리케이션 > 앱 키 > REST API 키
KAKAO_REST_API_KEY=여기에_REST_API_키

# 카카오 로그인 > Redirect URI 에 등록한 값과 '완전히 동일'해야 함
KAKAO_REDIRECT_URI=https://localhost:8080

# (선택) 앱에 '클라이언트 시크릿'을 '사용함'으로 켰다면 그 코드값을 여기에.
# 시크릿을 '사용 안 함'이면 비워두세요.
KAKAO_CLIENT_SECRET=

# 1이면 카카오 발송, 0이면 리포트만 생성
SEND_KAKAO=1

# (선택) 리포트를 웹에 게시해 카톡 '자세히 보기'로 폰에서 열기 — GitHub Pages
# GITHUB_REPO 는 공개(public) 저장소, GITHUB_TOKEN 은 contents 쓰기 권한 PAT
GITHUB_USER=깃허브사용자명
GITHUB_REPO=market-report
GITHUB_TOKEN=ghp_토큰
GITHUB_BRANCH=main
